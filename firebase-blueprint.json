{
  "entities": {
    "UserPreferences": {
      "title": "User Preferences",
      "description": "User specific preferences and stored data",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The user's auth UID"
        },
        "email": {
          "type": "string",
          "description": "User's email"
        },
        "baseCurrency": {
          "type": "string",
          "description": "Preferred base currency code"
        },
        "netWorth": {
          "type": "number",
          "description": "User's stored net worth"
        },
        "searchHistory": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of searched country or currency codes"
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether the user has admin privileges"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "email"
      ]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "A blog post article published on the site",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "summary": { "type": "string" },
        "content": { "type": "string" },
        "coverImageUrl": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "tags": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "published": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "slug", "content", "authorId", "authorName", "published", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserPreferences"
      },
      "description": "User profile document containing preferences"
    },
    "/posts/{postId}": {
      "schema": {
        "$ref": "#/entities/BlogPost"
      },
      "description": "Public and drafted blog posts"
    }
  }
}
